// Development Configuration
// 이 파일을 복사하여 Development.xcconfig로 사용하세요.
// Development.xcconfig는 .gitignore에 포함되어 있습니다.

// Backend API
API_BASE_URL = http:/$()/localhost:8000/api/v1

// App Identity
BUNDLE_IDENTIFIER = com.snail.app.dev
APP_DISPLAY_NAME = Snail Dev

// Feature Flags
ENABLE_DEBUG_MENU = YES
ENABLE_MOCK_API = NO
